<?xml version="1.0" encoding="utf-8"?>

                                                        

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/item_spacing"
        app:cardCornerRadius="12dp"
        app:cardElevation="2dp"
        app:strokeColor="@color/outlineVariant"
        app:strokeWidth="1dp" android:tag="layout/item_lesson_step_0" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="@dimen/content_padding"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/ivStepStatus"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_radio_button_unchecked"
                android:tint="@color/lesson_locked" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="@dimen/item_spacing"
                android:layout_marginEnd="@dimen/item_spacing">

                <TextView
                    android:id="@+id/tvStepNumber"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/color_primary" />

                <TextView
                    android:id="@+id/tvStepTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Step Title"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/onSurface"
                    android:layout_marginTop="2dp" />

                <TextView
                    android:id="@+id/tvStepInstruction"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Step instruction"
                    android:textSize="14sp"
                    android:textColor="@color/onSurfaceVariant"
                    android:layout_marginTop="4dp" />

            </LinearLayout>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
         