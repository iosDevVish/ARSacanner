<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/item_spacing"
        app:cardCornerRadius="12dp"
        app:cardElevation="2dp"
        app:strokeColor="@color/outlineVariant"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="@dimen/content_padding"
            android:gravity="center_vertical">

            <View
                android:id="@+id/guideSelectionIndicator"
                android:layout_width="4dp"
                android:layout_height="40dp"
                android:background="@color/color_primary"
                android:visibility="gone" />

            <ImageView
                android:id="@+id/ivGuideIcon"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginStart="@dimen/item_spacing"
                android:layout_marginEnd="@dimen/item_spacing"
                android:src="@drawable/ic_grid_on"
                android:tint="@color/onSurfaceVariant" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvGuideName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Grid"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/onSurface" />

                <TextView
                    android:id="@+id/tvGuideDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Show grid for proportion"
                    android:textSize="12sp"
                    android:textColor="@color/onSurfaceVariant" />
            </LinearLayout>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</layout>