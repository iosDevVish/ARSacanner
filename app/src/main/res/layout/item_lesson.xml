<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardLesson"
        android:layout_width="@dimen/lesson_card_width"
        android:layout_height="@dimen/lesson_card_height"
        android:layout_margin="@dimen/item_spacing"
        app:cardCornerRadius="@dimen/lesson_card_radius"
        app:cardElevation="@dimen/lesson_card_elevation"
        app:strokeColor="@color/outlineVariant"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="@dimen/item_spacing">

            <ImageView
                android:id="@+id/ivThumbnail"
                android:layout_width="match_parent"
                android:layout_height="@dimen/lesson_card_image_height"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_star"
                android:contentDescription="@string/lesson_thumbnail" />

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/lesson_title_basic_shapes"
                android:textSize="@dimen/lesson_title_text_size"
                android:textStyle="bold"
                android:textColor="@color/onSurface"
                android:layout_marginTop="@dimen/item_spacing" />

            <TextView
                android:id="@+id/tvDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/lesson_desc_basic_shapes"
                android:textSize="@dimen/lesson_desc_text_size"
                android:textColor="@color/onSurfaceVariant"
                android:layout_marginTop="4dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="@dimen/section_spacing"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvDifficulty"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Level 1"
                    android:textSize="@dimen/lesson_step_text_size"
                    android:textColor="@color/onSurfaceVariant" />

                <ProgressBar
                    android:id="@+id/progressBar"
                    style="@android:style/Widget.ProgressBar.Horizontal"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/lesson_progress_height"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="@dimen/item_spacing"
                    android:progress="0"
                    android:progressTint="@color/lesson_progress_fill"
                    android:progressBackgroundTint="@color/lesson_progress_bg" />

            </LinearLayout>

            <ImageView
                android:id="@+id/ivStatus"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="end"
                android:layout_marginTop="@dimen/item_spacing"
                android:src="@drawable/ic_lock"
                android:contentDescription="@string/lesson_status" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</layout>