package com.ardrawing.ardrawing.renderer

import android.content.Context
import android.opengl.GLES20
import android.opengl.GLES30
import android.opengl.Matrix
import android.util.Log
import com.ardrawing.ardrawing.drawing.DrawingStroke
import com.ardrawing.ardrawing.util.Point3D
import com.ardrawing.ardrawing.util.StrokeData
import java.nio.ByteBuffer
import java.nio.ByteOrder
import java.nio.FloatBuffer
import java.util.concurrent.ConcurrentLinkedQueue

class ARDrawingRenderer(private val context: Context) {
    private var program: Int = 0
    private var guideProgram: Int = 0
    private var planeProgram: Int = 0
    private var cursorProgram: Int = 0

    private var positionHandle: Int = 0
    private var colorHandle: Int = 0
    private var mvpMatrixHandle: Int = 0
    private var pointSizeHandle: Int = 0
    private var opacityHandle: Int = 0

    private var guidePositionHandle: Int = 0
    private var guideColorHandle: Int = 0
    private var guideMvpMatrixHandle: Int = 0
    private var guideLineWidthHandle: Int = 0

    private var planePositionHandle: Int = 0
    private var planeMvpMatrixHandle: Int = 0
    private var planeColorHandle: Int = 0

    private var cursorPositionHandle: Int = 0
    private var cursorMvpMatrixHandle: Int = 0
    private var cursorColorHandle: Int = 0
    private var cursorSizeHandle: Int = 0

    private val mvpMatrix = FloatArray(16)
    private val viewMatrix = FloatArray(16)
    private val projectionMatrix = FloatArray(16)
    private val modelMatrix = FloatArray(16)

    private val strokeQueue = ConcurrentLinkedQueue<StrokeData>()
    private val guideQueue = ConcurrentLinkedQueue<GuideData>()
    private var currentPlane: PlaneData? = null
    private var cursorPosition: Point3D? = null
    private var cursorColor: Int = 0xFF6750A4
    private var cursorSize: Float = 0.02f
    private var showCursor = true

    private val vertexBuffers = mutableMapOf<Long, FloatBuffer>()
    private val indexBuffers = mutableMapOf<Long, java.nio.ShortBuffer>()
    private val vertexCounts = mutableMapOf<Long, Int>()

    fun onSurfaceCreated() {
        GLES30.glClearColor(0f, 0f, 0f, 0f)
        GLES30.glEnable(GLES30.GL_DEPTH_TEST)
        GLES30.glEnable(GLES30.GL_BLEND)
        GLES30.glBlendFunc(GLES30.GL_SRC_ALPHA, GLES30.GL_ONE_MINUS_SRC_ALPHA)
        GLES30.glEnable(GLES30.GL_PROGRAM_POINT_SIZE)
        GLES30.glPointSize(10f)

        createPrograms()
    }

    private fun createPrograms() {
        program = createProgram(vertexShaderCode, fragmentShaderCode)
        guideProgram = createProgram(guideVertexShaderCode, guideFragmentShaderCode)
        planeProgram = createProgram(planeVertexShaderCode, planeFragmentShaderCode)
        cursorProgram = createProgram(cursorVertexShaderCode, cursorFragmentShaderCode)

        positionHandle = GLES30.glGetAttribLocation(program, "a_Position")
        colorHandle = GLES30.glGetUniformLocation(program, "u_Color")
        mvpMatrixHandle = GLES30.glGetUniformLocation(program, "u_MVPMatrix")
        pointSizeHandle = GLES30.glGetUniformLocation(program, "u_PointSize")
        opacityHandle = GLES30.glGetUniformLocation(program, "u_Opacity")

        guidePositionHandle = GLES30.glGetAttribLocation(guideProgram, "a_Position")
        guideColorHandle = GLES30.glGetUniformLocation(guideProgram, "u_Color")
        guideMvpMatrixHandle = GLES30.glGetUniformLocation(guideProgram, "u_MVPMatrix")
        guideLineWidthHandle = GLES30.glGetUniformLocation(guideProgram, "u_LineWidth")

        planePositionHandle = GLES30.glGetAttribLocation(planeProgram, "a_Position")
        planeMvpMatrixHandle = GLES30.glGetUniformLocation(planeProgram, "u_MVPMatrix")
        planeColorHandle = GLES30.glGetUniformLocation(planeProgram, "u_Color")

        cursorPositionHandle = GLES30.glGetAttribLocation(cursorProgram, "a_Position")
        cursorMvpMatrixHandle = GLES30.glGetUniformLocation(cursorProgram, "u_MVPMatrix")
        cursorColorHandle = GLES30.glGetUniformLocation(cursorProgram, "u_Color")
        cursorSizeHandle = GLES30.glGetUniformLocation(cursorProgram, "u_Size")
    }

    private fun createProgram(vertexCode: String, fragmentCode: String): Int {
        val vertexShader = loadShader(GLES30.GL_VERTEX_SHADER, vertexCode)
        val fragmentShader = loadShader(GLES30.GL_FRAGMENT_SHADER, fragmentCode)
        val program = GLES30.glCreateProgram()
        GLES30.glAttachShader(program, vertexShader)
        GLES30.glAttachShader(program, fragmentShader)
        GLES30.glLinkProgram(program)
        val linkStatus = IntArray(1)
        GLES30.glGetProgramiv(program, GLES30.GL_LINK_STATUS, linkStatus, 0)
        if (linkStatus[0] == 0) {
            Log.e("ARDrawingRenderer", "Program link error: ${GLES30.glGetProgramInfoLog(program)}")
        }
        return program
    }

    private fun loadShader(type: Int, code: String): Int {
        val shader = GLES30.glCreateShader(type)
        GLES30.glShaderSource(shader, code)
        GLES30.glCompileShader(shader)
        val compileStatus = IntArray(1)
        GLES30.glGetShaderiv(shader, GLES30.GL_COMPILE_STATUS, compileStatus, 0)
        if (compileStatus[0] == 0) {
            Log.e("ARDrawingRenderer", "Shader compile error: ${GLES30.glGetShaderInfoLog(shader)}")
        }
        return shader
    }

    fun onSurfaceChanged(width: Int, height: Int) {
        GLES30.glViewport(0, 0, width, height)
        val ratio = width.toFloat() / height.toFloat()
        Matrix.frustumM(projectionMatrix, 0, -ratio, ratio, -1f, 1f, 1f, 100f)
    }

    fun onDrawFrame(viewMatrix: FloatArray, projectionMatrix: FloatArray) {
        this.viewMatrix = viewMatrix.clone()
        this.projectionMatrix = projectionMatrix.clone()

        GLES30.glClear(GLES30.GL_COLOR_BUFFER_BIT or GLES30.GL_DEPTH_BUFFER_BIT)

        drawPlane()
        drawGuides()
        drawStrokes()
        drawCursor()
    }

    private fun drawPlane() {
        currentPlane?.let { plane ->
            GLES30.glUseProgram(planeProgram)
            Matrix.setIdentityM(modelMatrix, 0)
            Matrix.translateM(modelMatrix, 0, plane.center.x, plane.center.y, plane.center.z)
            Matrix.rotateM(modelMatrix, 0, -90f, 1f, 0f, 0f)
            Matrix.scaleM(modelMatrix, 0, plane.extent.x * 2, plane.extent.z * 2, 1f)
            Matrix.multiplyMM(mvpMatrix, 0, projectionMatrix, 0, viewMatrix, 0)
            Matrix.multiplyMM(mvpMatrix, 0, mvpMatrix, 0, modelMatrix, 0)

            GLES30.glUniformMatrix4fv(planeMvpMatrixHandle, 1, false, mvpMatrix, 0)
            GLES30.glUniform4fv(planeColorHandle, 1, floatArrayOf(
                ((plane.color shr 16) and 0xFF) / 255f,
                ((plane.color shr 8) and 0xFF) / 255f,
                (plane.color and 0xFF) / 255f,
                ((plane.color shr 24) and 0xFF) / 255f
            ), 0)

            val vertexBuffer = ByteBuffer.allocateDirect(planeVertices.size * 4).order(ByteOrder.nativeOrder()).asFloatBuffer().apply { put(planeVertices) ; position(0) }
            GLES30.glEnableVertexAttribArray(planePositionHandle)
            GLES30.glVertexAttribPointer(planePositionHandle, 3, GLES30.GL_FLOAT, false, 12, vertexBuffer)
            GLES30.glDrawArrays(GLES30.GL_TRIANGLE_FAN, 0, planeVertices.size / 3)
            GLES30.glDisableVertexAttribArray(planePositionHandle)
        }
    }

    private val planeVertices = floatArrayOf(
        0f, 0f, 0f,
        -1f, -1f, 0f,
        1f, -1f, 0f,
        1f, 1f, 0f,
        -1f, 1f, 0f,
        -1f, -1f, 0f
    )

    private fun drawGuides() {
        GLES30.glUseProgram(guideProgram)
        Matrix.multiplyMM(mvpMatrix, 0, projectionMatrix, 0, viewMatrix, 0)

        while (!guideQueue.isEmpty()) {
            val guide = guideQueue.poll() ?: continue
            drawGuide(guide)
        }
    }

    private fun drawGuide(guide: GuideData) {
        val vertices = guide.vertices
        val vertexBuffer = ByteBuffer.allocateDirect(vertices.size * 4).order(ByteOrder.nativeOrder()).asFloatBuffer().apply { put(vertices); position(0) }

        GLES30.glUniformMatrix4fv(guideMvpMatrixHandle, 1, false, mvpMatrix, 0)
        GLES30.glUniform4fv(guideColorHandle, 1, floatArrayOf(
            ((guide.color shr 16) and 0xFF) / 255f,
            ((guide.color shr 8) and 0xFF) / 255f,
            (guide.color and 0xFF) / 255f,
            guide.opacity
        ), 0)
        GLES30.glUniform1f(guideLineWidthHandle, guide.lineWidth)

        GLES30.glEnableVertexAttribArray(guidePositionHandle)
        GLES30.glVertexAttribPointer(guidePositionHandle, 3, GLES30.GL_FLOAT, false, 12, vertexBuffer)
        GLES30.glDrawArrays(guide.drawMode, 0, vertices.size / 3)
        GLES30.glDisableVertexAttribArray(guidePositionHandle)
    }

    private fun drawStrokes() {
        GLES30.glUseProgram(program)
        Matrix.multiplyMM(mvpMatrix, 0, projectionMatrix, 0, viewMatrix, 0)

        while (!strokeQueue.isEmpty()) {
            val stroke = strokeQueue.poll() ?: continue
            drawStroke(stroke)
        }
    }

    private fun drawStroke(stroke: StrokeData) {
        val key = stroke.id
        var vertexBuffer = vertexBuffers[key]
        var indexBuffer = indexBuffers[key]
        var count = vertexCounts[key]

        if (vertexBuffer == null || vertexBuffer.capacity() < stroke.points.size * 3) {
            vertexBuffer = ByteBuffer.allocateDirect(stroke.points.size * 12).order(ByteOrder.nativeOrder()).asFloatBuffer()
            vertexBuffers[key] = vertexBuffer
        }
        vertexBuffer.position(0)
        stroke.points.forEach { p ->
            vertexBuffer.put(p.x).put(p.y).put(p.z)
        }
        vertexBuffer.position(0)
        count = stroke.points.size
        vertexCounts[key] = count

        GLES30.glUniformMatrix4fv(mvpMatrixHandle, 1, false, mvpMatrix, 0)
        GLES30.glUniform4fv(colorHandle, 1, floatArrayOf(
            ((stroke.color shr 16) and 0xFF) / 255f,
            ((stroke.color shr 8) and 0xFF) / 255f,
            (stroke.color and 0xFF) / 255f,
            stroke.opacity
        ), 0)
        GLES30.glUniform1f(pointSizeHandle, stroke.brushSize * 0.01f)
        GLES30.glUniform1f(opacityHandle, stroke.opacity)

        GLES30.glEnableVertexAttribArray(positionHandle)
        GLES30.glVertexAttribPointer(positionHandle, 3, GLES30.GL_FLOAT, false, 12, vertexBuffer)
        GLES30.glDrawArrays(GLES30.GL_LINE_STRIP, 0, count)
        GLES30.glDisableVertexAttribArray(positionHandle)

        if (stroke.toolType == 1) {
            GLES30.glDrawArrays(GLES30.GL_POINTS, 0, count)
        }
    }

    private fun drawCursor() {
        if (!showCursor || cursorPosition == null) return

        GLES30.glUseProgram(cursorProgram)
        Matrix.setIdentityM(modelMatrix, 0)
        Matrix.translateM(modelMatrix, 0, cursorPosition!!.x, cursorPosition!!.y, cursorPosition!!.z)
        Matrix.scaleM(modelMatrix, 0, cursorSize, cursorSize, cursorSize)
        Matrix.multiplyMM(mvpMatrix, 0, projectionMatrix, 0, viewMatrix, 0)
        Matrix.multiplyMM(mvpMatrix, 0, mvpMatrix, 0, modelMatrix, 0)

        GLES30.glUniformMatrix4fv(cursorMvpMatrixHandle, 1, false, mvpMatrix, 0)
        GLES30.glUniform4fv(cursorColorHandle, 1, floatArrayOf(
            ((cursorColor shr 16) and 0xFF) / 255f,
            ((cursorColor shr 8) and 0xFF) / 255f,
            (cursorColor and 0xFF) / 255f,
            1f
        ), 0)
        GLES30.glUniform1f(cursorSizeHandle, cursorSize)

        val cursorVertices = floatArrayOf(
            0f, 0f, 0f,
            -0.5f, -0.5f, 0f,
            0.5f, -0.5f, 0f,
            0.5f, 0.5f, 0f,
            -0.5f, 0.5f, 0f,
            -0.5f, -0.5f, 0f
        )
        val vertexBuffer = ByteBuffer.allocateDirect(cursorVertices.size * 4).order(ByteOrder.nativeOrder()).asFloatBuffer().apply { put(cursorVertices); position(0) }

        GLES30.glEnableVertexAttribArray(cursorPositionHandle)
        GLES30.glVertexAttribPointer(cursorPositionHandle, 3, GLES30.GL_FLOAT, false, 12, vertexBuffer)
        GLES30.glDrawArrays(GLES30.GL_TRIANGLE_FAN, 0, 6)
        GLES30.glDisableVertexAttribArray(cursorPositionHandle)
    }

    fun addStroke(stroke: StrokeData) {
        strokeQueue.add(stroke)
    }

    fun addGuide(guide: GuideData) {
        guideQueue.add(guide)
    }

    fun setPlane(plane: PlaneData?) {
        currentPlane = plane
    }

    fun setCursorPosition(position: Point3D?) {
        cursorPosition = position
    }

    fun setCursorColor(color: Int) {
        cursorColor = color
    }

    fun setCursorSize(size: Float) {
        cursorSize = size
    }

    fun setShowCursor(show: Boolean) {
        showCursor = show
    }

    fun clear() {
        strokeQueue.clear()
        guideQueue.clear()
        vertexBuffers.values.forEach { it.clear() }
        indexBuffers.values.forEach { it.clear() }
        vertexBuffers.clear()
        indexBuffers.clear()
        vertexCounts.clear()
    }

    companion object {
        private const val vertexShaderCode = """
            attribute vec4 a_Position;
            uniform mat4 u_MVPMatrix;
            uniform float u_PointSize;
            void main() {
                gl_Position = u_MVPMatrix * a_Position;
                gl_PointSize = u_PointSize;
            }
        """.trimIndent()

        private const val fragmentShaderCode = """
            precision mediump float;
            uniform vec4 u_Color;
            uniform float u_Opacity;
            void main() {
                gl_FragColor = vec4(u_Color.rgb, u_Color.a * u_Opacity);
            }
        """.trimIndent()

        private const val guideVertexShaderCode = """
            attribute vec4 a_Position;
            uniform mat4 u_MVPMatrix;
            void main() {
                gl_Position = u_MVPMatrix * a_Position;
            }
        """.trimIndent()

        private const val guideFragmentShaderCode = """
            precision mediump float;
            uniform vec4 u_Color;
            uniform float u_LineWidth;
            void main() {
                gl_FragColor = u_Color;
            }
        """.trimIndent()

        private const val planeVertexShaderCode = """
            attribute vec4 a_Position;
            uniform mat4 u_MVPMatrix;
            void main() {
                gl_Position = u_MVPMatrix * a_Position;
            }
        """.trimIndent()

        private const val planeFragmentShaderCode = """
            precision mediump float;
            uniform vec4 u_Color;
            void main() {
                gl_FragColor = u_Color;
            }
        """.trimIndent()

        private const val cursorVertexShaderCode = """
            attribute vec4 a_Position;
            uniform mat4 u_MVPMatrix;
            void main() {
                gl_Position = u_MVPMatrix * a_Position;
            }
        """.trimIndent()

        private const val cursorFragmentShaderCode = """
            precision mediump float;
            uniform vec4 u_Color;
            uniform float u_Size;
            void main() {
                float dist = length(gl_PointCoord - vec2(0.5));
                if (dist > 0.5) discard;
                float alpha = 1.0 - smoothstep(0.3, 0.5, dist);
                gl_FragColor = vec4(u_Color.rgb, u_Color.a * alpha);
            }
        """.trimIndent()
    }
}

data class StrokeData(
    val id: Long = System.currentTimeMillis(),
    val points: List<Point3D>,
    val color: Int,
    val brushSize: Float,
    val opacity: Float,
    val toolType: Int
)

data class GuideData(
    val vertices: FloatArray,
    val color: Int,
    val opacity: Float = 0.6f,
    val lineWidth: Float = 2f,
    val drawMode: Int = 3 // GLES30.GL_LINE_STRIP = 0x8003
)

data class PlaneData(
    val center: Point3D,
    val extent: Point3D,
    val color: Int = 0x806750A4
)