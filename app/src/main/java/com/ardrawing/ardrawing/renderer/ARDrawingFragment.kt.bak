package com.ardrawing.ardrawing.renderer

import android.content.Context
import android.opengl.GLES30
import android.opengl.Matrix
import android.util.Log
import com.google.ar.core.Anchor
import com.google.ar.core.Frame
import com.google.ar.core.HitResult
import com.google.ar.core.Plane
import com.google.ar.core.Session
import com.google.ar.core.Trackable
import com.google.ar.core.TrackingState
import com.google.ar.core.exceptions.CameraNotAvailableException
import com.google.ar.sceneform.FrameTime
import com.google.ar.sceneform.Scene
import com.google.ar.sceneform.math.Vector3
import com.google.ar.sceneform.rendering.Color
import com.google.ar.sceneform.rendering.MaterialFactory
import com.google.ar.sceneform.rendering.ModelRenderable
import com.google.ar.sceneform.rendering.Renderable
import com.google.ar.sceneform.rendering.ViewRenderable
import com.google.ar.sceneform.ux.ArFragment
import com.google.ar.sceneform.ux.TransformableNode
import com.ardrawing.ardrawing.drawing.DrawingGuide
import com.ardrawing.ardrawing.drawing.DrawingStroke
import com.ardrawing.ardrawing.drawing.DrawingState
import com.ardrawing.ardrawing.drawing.ToolType
import com.ardrawing.ardrawing.util.Point3D
import com.ardrawing.ardrawing.util.StrokeData
import kotlinx.coroutines.CoroutineScope
import kotlinx.coroutines.Dispatchers
import kotlinx.coroutines.launch
import java.nio.ByteBuffer
import java.nio.ByteOrder
import java.nio.FloatBuffer

class ARDrawingFragment : ArFragment() {
    private var drawingRenderer: ARDrawingRenderer? = null
    private var currentAnchor: Anchor? = null
    private var drawingPlane: Plane? = null
    private var isDrawingEnabled = false
    private var currentTool = ToolType.BRUSH
    private var currentColor = 0xFF6750A4.toInt()
    private var currentBrushSize = 8f
    private var currentOpacity = 1f
    private var drawingState = DrawingState()
    private val strokeHistory = mutableListOf<DrawingStroke>()
    private val redoHistory = mutableListOf<DrawingStroke>()
    private var activeGuide: DrawingGuide? = null
    private var guideRenderer: GuideRenderer? = null
    private var planeRenderer: PlaneRenderer? = null
    private var cursorRenderer: CursorRenderer? = null
    private val scope = CoroutineScope(Dispatchers.Main)
    private var session: Session? = null

    interface OnDrawingStateChangedListener {
        fun onDrawingStarted()
        fun onDrawingStopped()
        fun onStrokeAdded(stroke: DrawingStroke)
        fun onStrokeRemoved()
        fun onUndoRedoStateChanged(canUndo: Boolean, canRedo: Boolean)
        fun onTrackingStateChanged(state: TrackingState)
        fun onPlaneDetected(plane: Plane)
    }

    private var listener: OnDrawingStateChangedListener? = null

    fun setOnDrawingStateChangedListener(listener: OnDrawingStateChangedListener) {
        this.listener = listener
    }

    override fun onResume() {
        super.onResume()
        setupScene()
    }

    private fun setupScene() {
        scene.addOnUpdateListener(this::onSceneUpdate)
        drawingRenderer = ARDrawingRenderer(requireContext())
        guideRenderer = GuideRenderer(requireContext())
        planeRenderer = PlaneRenderer(requireContext())
        cursorRenderer = CursorRenderer(requireContext())

        scene.addChild(guideRenderer!!)
        scene.addChild(planeRenderer!!)
        scene.addChild(cursorRenderer!!)
    }

    private fun onSceneUpdate(frameTime: FrameTime) {
        val frame = arSceneView.arFrame ?: return
        val camera = frame.camera
        val projectionMatrix = FloatArray(16)
        val viewMatrix = FloatArray(16)
        camera.getProjectionMatrix(projectionMatrix, 0, 0.1f, 100f)
        camera.getViewMatrix(viewMatrix, 0)

        val mvpMatrix = FloatArray(16)
        Matrix.multiplyMM(mvpMatrix, 0, projectionMatrix, 0, viewMatrix, 0)

        drawingRenderer?.setMVPMatrix(mvpMatrix)
        guideRenderer?.setMVPMatrix(mvpMatrix)
        planeRenderer?.setMVPMatrix(mvpMatrix)
        cursorRenderer?.setMVPMatrix(mvpMatrix)

        updateTrackingState(frame)
        updatePlanes(frame)
    }

    private fun updateTrackingState(frame: Frame) {
        val state = when (frame.camera.trackingState) {
            TrackingState.TRACKING -> TrackingState.NORMAL
            TrackingState.PAUSED -> TrackingState.LIMITED
            else -> TrackingState.NONE
        }
        listener?.onTrackingStateChanged(state)
    }

    private fun updatePlanes(frame: Frame) {
        val planes = frame.getUpdatedTrackables(Plane::class.java)
        for (plane in planes) {
            if (plane.trackingState == TrackingState.TRACKING && plane.type == Plane.Type.HORIZONTAL_UPWARD_FACING) {
                if (drawingPlane == null) {
                    drawingPlane = plane
                    listener?.onPlaneDetected(plane)
                    showPlane(plane)
                }
                planeRenderer?.addPlane(plane)
            }
        }
    }

    private fun showPlane(plane: Plane) {
        planeRenderer?.showPlane(plane)
    }

    fun onTap(x: Float, y: Float) {
        if (!isDrawingEnabled) {
            startDrawingAt(x, y)
        } else {
            stopDrawing()
        }
    }

    private fun startDrawingAt(x: Float, y: Float) {
        val frame = arSceneView.arFrame ?: return
        val hitResults = frame.hitTest(x, y)
        for (hit in hitResults) {
            val trackable = hit.trackable
            if (trackable is Plane && trackable.trackingState == TrackingState.TRACKING) {
                currentAnchor = hit.createAnchor()
                drawingPlane = trackable
                isDrawingEnabled = true
                drawingState = DrawingState()
                strokeHistory.clear()
                redoHistory.clear()
                listener?.onDrawingStarted()
                listener?.onUndoRedoStateChanged(false, false)
                cursorRenderer?.setAnchor(currentAnchor!!)
                cursorRenderer?.setVisible(true)
                return
            }
        }
    }

    fun stopDrawing() {
        isDrawingEnabled = false
        currentAnchor?.detach()
        currentAnchor = null
        drawingPlane = null
        cursorRenderer?.setVisible(false)
        listener?.onDrawingStopped()
    }

    fun addPoint(point: Point3D) {
        if (!isDrawingEnabled || currentAnchor == null) return

        val newStroke = DrawingStroke(
            points = drawingState.currentStroke?.points?.plus(point) ?: listOf(point),
            color = currentColor,
            brushSize = currentBrushSize,
            opacity = currentOpacity,
            toolType = currentTool
        )

        drawingState = drawingState.withNewStroke(newStroke)
        drawingRenderer?.addStroke(newStroke.toStrokeData())
        listener?.onStrokeAdded(newStroke)
    }

    fun endStroke() {
        if (drawingState.currentStroke != null) {
            val stroke = drawingState.currentStroke!!
            drawingState = drawingState.addStroke(stroke)
            strokeHistory.add(stroke)
            redoHistory.clear()
            listener?.onUndoRedoStateChanged(strokeHistory.size > 1, false)
        }
    }

    fun undo() {
        if (strokeHistory.isNotEmpty()) {
            val stroke = strokeHistory.removeLast()
            redoHistory.add(stroke)
            drawingRenderer?.removeStroke(stroke.id)
            drawingState = drawingState.undo()
            listener?.onStrokeRemoved()
            listener?.onUndoRedoStateChanged(strokeHistory.size > 1, redoHistory.isNotEmpty())
        }
    }

    fun redo() {
        if (redoHistory.isNotEmpty()) {
            val stroke = redoHistory.removeLast()
            strokeHistory.add(stroke)
            drawingRenderer?.addStroke(stroke.toStrokeData())
            drawingState = drawingState.addStroke(stroke)
            listener?.onStrokeAdded(stroke)
            listener?.onUndoRedoStateChanged(strokeHistory.size > 1, redoHistory.isNotEmpty())
        }
    }

    fun clear() {
        drawingRenderer?.clear()
        strokeHistory.clear()
        redoHistory.clear()
        drawingState = drawingState.clear()
        listener?.onUndoRedoStateChanged(false, false)
    }

    fun setTool(tool: ToolType) {
        currentTool = tool
    }

    fun setColor(color: Int) {
        currentColor = color
    }

    fun setBrushSize(size: Float) {
        currentBrushSize = size
    }

    fun setOpacity(opacity: Float) {
        currentOpacity = opacity
    }

    fun setActiveGuide(guide: DrawingGuide?) {
        activeGuide = guide
        guideRenderer?.setGuide(guide)
    }

    fun getDrawingState(): DrawingState {
        return drawingState
    }

    fun saveDrawing(): String {
        val gson = com.google.gson.Gson()
        return gson.toJson(drawingState.strokes)
    }

    fun loadDrawing(json: String) {
        val gson = com.google.gson.Gson()
        val strokes = gson.fromJson(json, Array<StrokeData>::class.java).toList()
        drawingRenderer?.clear()
        strokeHistory.clear()
        redoHistory.clear()
        drawingState = DrawingState()
        for (strokeData in strokes) {
            val stroke = DrawingStroke.fromStrokeData(strokeData)
            drawingRenderer?.addStroke(strokeData)
            drawingState = drawingState.addStroke(stroke)
            strokeHistory.add(stroke)
        }
        listener?.onUndoRedoStateChanged(strokeHistory.size > 1, false)
    }

    override fun onDestroy() {
        drawingRenderer?.clear()
        guideRenderer?.clear()
        planeRenderer?.clear()
        cursorRenderer?.clear()
        super.onDestroy()
    }

    enum class TrackingState {
        NORMAL, LIMITED, NONE
    }
}

class ARDrawingRenderer(private val context: Context) : Renderable {
    private var program: Int = 0
    private var mvpMatrix: FloatArray = FloatArray(16)
    private val strokes = mutableListOf<StrokeData>()
    private val vertexBuffers = mutableMapOf<Long, Int>()
    private val indexBuffers = mutableMapOf<Long, Int>()
    private val vertexCounts = mutableMapOf<Long, Int>()

    fun setMVPMatrix(matrix: FloatArray) {
        mvpMatrix = matrix.clone()
    }

    fun addStroke(stroke: StrokeData) {
        strokes.add(stroke)
        createBuffers(stroke)
    }

    fun removeStroke(id: Long) {
        strokes.removeAll { it.id == id }
        vertexBuffers.remove(id)?.let { GLES30.glDeleteBuffers(1, intArrayOf(it), 0) }
        indexBuffers.remove(id)?.let { GLES30.glDeleteBuffers(1, intArrayOf(it), 0) }
        vertexCounts.remove(id)
    }

    fun clear() {
        strokes.clear()
        vertexBuffers.values.forEach { GLES30.glDeleteBuffers(1, intArrayOf(it), 0) }
        indexBuffers.values.forEach { GLES30.glDeleteBuffers(1, intArrayOf(it), 0) }
        vertexBuffers.clear()
        indexBuffers.clear()
        vertexCounts.clear()
    }

    private fun createBuffers(stroke: StrokeData) {
        val vertices = FloatArray(stroke.points.size * 3)
        for (i in stroke.points.indices) {
            val p = stroke.points[i]
            vertices[i * 3] = p.x
            vertices[i * 3 + 1] = p.y
            vertices[i * 3 + 2] = p.z
        }

        val vertexBuffer = IntArray(1)
        GLES30.glGenBuffers(1, vertexBuffer, 0)
        GLES30.glBindBuffer(GLES30.GL_ARRAY_BUFFER, vertexBuffer[0])
        GLES30.glBufferData(GLES30.GL_ARRAY_BUFFER, vertices.size * 4, ByteBuffer.wrap(toByteArray(vertices)).order(ByteOrder.nativeOrder()), GLES30.GL_STATIC_DRAW)

        vertexBuffers[stroke.id] = vertexBuffer[0]
        vertexCounts[stroke.id] = stroke.points.size
    }

    override fun render(renderContext: RenderContext?) {
        if (program == 0) {
            createProgram()
        }

        GLES30.glUseProgram(program)
        val mvpHandle = GLES30.glGetUniformLocation(program, "u_MVPMatrix")
        GLES30.glUniformMatrix4fv(mvpHandle, 1, false, mvpMatrix, 0)

        val pointSizeHandle = GLES30.glGetUniformLocation(program, "u_PointSize")
        val colorHandle = GLES30.glGetUniformLocation(program, "u_Color")
        val opacityHandle = GLES30.glGetUniformLocation(program, "u_Opacity")
        val positionHandle = GLES30.glGetAttribLocation(program, "a_Position")

        GLES30.glEnableVertexAttribArray(positionHandle)

        for (stroke in strokes) {
            val vertexBuffer = vertexBuffers[stroke.id] ?: continue
            val count = vertexCounts[stroke.id] ?: continue

            GLES30.glBindBuffer(GLES30.GL_ARRAY_BUFFER, vertexBuffer)
            GLES30.glVertexAttribPointer(positionHandle, 3, GLES30.GL_FLOAT, false, 12, 0)

            val color = FloatArray(4)
            color[0] = ((stroke.color shr 16) and 0xFF) / 255f
            color[1] = ((stroke.color shr 8) and 0xFF) / 255f
            color[2] = (stroke.color and 0xFF) / 255f
            color[3] = ((stroke.color shr 24) and 0xFF) / 255f

            GLES30.glUniform4fv(colorHandle, 1, color, 0)
            GLES30.glUniform1f(opacityHandle, stroke.opacity)
            GLES30.glUniform1f(pointSizeHandle, stroke.brushSize)

            if (stroke.toolType == 1) {
                GLES30.glEnable(GLES30.GL_BLEND)
                GLES30.glBlendFunc(GLES30.GL_ONE, GLES30.GL_ZERO)
            }

            GLES30.glDrawArrays(GLES30.GL_POINTS, 0, count)

            if (stroke.toolType == 1) {
                GLES30.glDisable(GLES30.GL_BLEND)
            }
        }

        GLES30.glDisableVertexAttribArray(positionHandle)
    }

    private fun createProgram() {
        val vertexShader = loadShader(GLES30.GL_VERTEX_SHADER, vertexShaderCode)
        val fragmentShader = loadShader(GLES30.GL_FRAGMENT_SHADER, fragmentShaderCode)
        program = GLES30.glCreateProgram()
        GLES30.glAttachShader(program, vertexShader)
        GLES30.glAttachShader(program, fragmentShader)
        GLES30.glLinkProgram(program)
    }

    private fun loadShader(type: Int, code: String): Int {
        val shader = GLES30.glCreateShader(type)
        GLES30.glShaderSource(shader, code)
        GLES30.glCompileShader(shader)
        return shader
    }

    private fun toByteArray(floats: FloatArray): ByteArray {
        val buffer = ByteBuffer.allocateDirect(floats.size * 4)
        buffer.order(ByteOrder.nativeOrder())
        buffer.asFloatBuffer().put(floats)
        return buffer.array()
    }

    companion object {
        private const val vertexShaderCode = """
            uniform mat4 u_MVPMatrix;
            uniform float u_PointSize;
            attribute vec4 a_Position;
            void main() {
                gl_Position = u_MVPMatrix * a_Position;
                gl_PointSize = u_PointSize;
            }
        """.trimIndent()

        private const val fragmentShaderCode = """
            precision mediump float;
            uniform vec4 u_Color;
            uniform float u_Opacity;
            void main() {
                gl_FragColor = vec4(u_Color.rgb, u_Color.a * u_Opacity);
            }
        """.trimIndent()
    }
}

class GuideRenderer(private val context: Context) : Renderable {
    private var program: Int = 0
    private var mvpMatrix: FloatArray = FloatArray(16)
    private var currentGuide: DrawingGuide? = null
    private var vertexBuffer: Int = 0
    private var vertexCount = 0

    fun setMVPMatrix(matrix: FloatArray) {
        mvpMatrix = matrix.clone()
    }

    fun setGuide(guide: DrawingGuide?) {
        currentGuide = guide
        if (guide != null) {
            generateGuideGeometry(guide)
        } else {
            clearGuide()
        }
    }

    private fun generateGuideGeometry(guide: DrawingGuide) {
        val vertices = when (guide) {
            DrawingGuide.GRID -> generateGrid(10, 1f)
            DrawingGuide.PERSPECTIVE -> generatePerspectiveGrid()
            DrawingGuide.CIRCLE -> generateCircle(0.5f, 32)
            DrawingGuide.LINE -> generateLine(-0.5f, 0f, 0.5f, 0f)
            DrawingGuide.SYMMETRY -> generateSymmetryLines()
            DrawingGuide.PERSPECTIVE_GRID -> generatePerspectiveGrid()
            DrawingGuide.ISOMETRIC -> generateIsometricGrid()
            else -> floatArrayOf()
        }

        if (vertices.isNotEmpty()) {
            val buffer = IntArray(1)
            GLES30.glGenBuffers(1, buffer, 0)
            GLES30.glBindBuffer(GLES30.GL_ARRAY_BUFFER, buffer[0])
            GLES30.glBufferData(GLES30.GL_ARRAY_BUFFER, vertices.size * 4, ByteBuffer.wrap(toByteArray(vertices)).order(ByteOrder.nativeOrder()), GLES30.GL_STATIC_DRAW)
            vertexBuffer = buffer[0]
            vertexCount = vertices.size / 3
        }
    }

    private fun clearGuide() {
        if (vertexBuffer != 0) {
            GLES30.glDeleteBuffers(1, intArrayOf(vertexBuffer), 0)
            vertexBuffer = 0
            vertexCount = 0
        }
    }

    override fun render(renderContext: RenderContext?) {
        if (program == 0) createProgram()
        if (currentGuide == null || vertexCount == 0) return

        GLES30.glUseProgram(program)
        val mvpHandle = GLES30.glGetUniformLocation(program, "u_MVPMatrix")
        GLES30.glUniformMatrix4fv(mvpHandle, 1, false, mvpMatrix, 0)

        val colorHandle = GLES30.glGetUniformLocation(program, "u_Color")
        val lineWidthHandle = GLES30.glGetUniformLocation(program, "u_LineWidth")
        val positionHandle = GLES30.glGetAttribLocation(program, "a_Position")

        GLES30.glEnableVertexAttribArray(positionHandle)
        GLES30.glBindBuffer(GLES30.GL_ARRAY_BUFFER, vertexBuffer)
        GLES30.glVertexAttribPointer(positionHandle, 3, GLES30.GL_FLOAT, false, 12, 0)

        val color = floatArrayOf(0.4f, 0.31f, 0.64f, 0.6f)
        GLES30.glUniform4fv(colorHandle, 1, color, 0)
        GLES30.glUniform1f(lineWidthHandle, 2f)

        GLES30.glDrawArrays(GLES30.GL_LINE_STRIP, 0, vertexCount)

        GLES30.glDisableVertexAttribArray(positionHandle)
    }

    fun clear() {
        clearGuide()
    }

    private fun createProgram() {
        val vertexShader = loadShader(GLES30.GL_VERTEX_SHADER, guideVertexShaderCode)
        val fragmentShader = loadShader(GLES30.GL_FRAGMENT_SHADER, guideFragmentShaderCode)
        program = GLES30.glCreateProgram()
        GLES30.glAttachShader(program, vertexShader)
        GLES30.glAttachShader(program, fragmentShader)
        GLES30.glLinkProgram(program)
    }

    private fun loadShader(type: Int, code: String): Int {
        val shader = GLES30.glCreateShader(type)
        GLES30.glShaderSource(shader, code)
        GLES30.glCompileShader(shader)
        return shader
    }

    private fun toByteArray(floats: FloatArray): ByteArray {
        val buffer = ByteBuffer.allocateDirect(floats.size * 4)
        buffer.order(ByteOrder.nativeOrder())
        buffer.asFloatBuffer().put(floats)
        return buffer.array()
    }

    private fun generateGrid(size: Int, spacing: Float): FloatArray {
        val vertices = mutableListOf<Float>()
        val half = size * spacing / 2
        for (i in 0..size) {
            val offset = -half + i * spacing
            vertices.addAll(listOf(offset, 0f, -half, offset, 0f, half))
            vertices.addAll(listOf(-half, 0f, offset, half, 0f, offset))
        }
        return vertices.toFloatArray()
    }

    private fun generatePerspectiveGrid(): FloatArray {
        val vertices = mutableListOf<Float>()
        val center = Point3D(0f, 0f, 0f)
        for (i in 1..8) {
            val scale = i * 0.1f
            vertices.addAll(listOf(-scale, 0f, -scale, scale, 0f, -scale))
            vertices.addAll(listOf(-scale, 0f, scale, scale, 0f, scale))
            vertices.addAll(listOf(-scale, 0f, -scale, -scale, 0f, scale))
            vertices.addAll(listOf(scale, 0f, -scale, scale, 0f, scale))
        }
        return vertices.toFloatArray()
    }

    private fun generateCircle(radius: Float, segments: Int): FloatArray {
        val vertices = mutableListOf<Float>()
        for (i in 0..segments) {
            val angle = 2 * Math.PI * i / segments
            vertices.addAll(listOf((radius * Math.cos(angle)).toFloat(), 0f, (radius * Math.sin(angle)).toFloat()))
        }
        return vertices.toFloatArray()
    }

    private fun generateLine(x1: Float, y1: Float, x2: Float, y2: Float): FloatArray {
        return floatArrayOf(x1, 0f, y1, x2, 0f, y2)
    }

    private fun generateSymmetryLines(): FloatArray {
        return floatArrayOf(-1f, 0f, 0f, 1f, 0f, 0f, 0f, 0f, -1f, 0f, 0f, 1f)
    }

    private fun generateIsometricGrid(): FloatArray {
        val vertices = mutableListOf<Float>()
        val spacing = 0.2f
        for (i in -5..5) {
            val offset = i * spacing
            vertices.addAll(listOf(-1f, 0f, offset, 1f, 0f, offset))
            vertices.addAll(listOf(offset, 0f, -1f, offset, 0f, 1f))
            vertices.addAll(listOf(-1f, 0f, offset * 0.577f, 1f, 0f, -offset * 0.577f))
        }
        return vertices.toFloatArray()
    }

    companion object {
        private const val guideVertexShaderCode = """
            uniform mat4 u_MVPMatrix;
            attribute vec4 a_Position;
            void main() {
                gl_Position = u_MVPMatrix * a_Position;
            }
        """.trimIndent()

        private const val guideFragmentShaderCode = """
            precision mediump float;
            uniform vec4 u_Color;
            uniform float u_LineWidth;
            void main() {
                gl_FragColor = u_Color;
            }
        """.trimIndent()
    }
}

class PlaneRenderer(private val context: Context) : Renderable {
    private var program: Int = 0
    private var mvpMatrix: FloatArray = FloatArray(16)
    private val planes = mutableMapOf<Plane, PlaneData>()

    fun setMVPMatrix(matrix: FloatArray) {
        mvpMatrix = matrix.clone()
    }

    fun addPlane(plane: Plane) {
        val polygons = plane.polygon
        val vertices = FloatArray(polygons.size * 3)
        for (i in polygons.indices) {
            vertices[i * 3] = polygons[i].x
            vertices[i * 3 + 1] = polygons[i].y
            vertices[i * 3 + 2] = polygons[i].z
        }
        planes[plane] = PlaneData(vertices)
    }

    fun showPlane(plane: Plane) {
        plane.renderable?.let { scene.removeChild(it) }
    }

    override fun render(renderContext: RenderContext?) {
        if (program == 0) createProgram()
        if (planes.isEmpty()) return

        GLES30.glUseProgram(program)
        val mvpHandle = GLES30.glGetUniformLocation(program, "u_MVPMatrix")
        GLES30.glUniformMatrix4fv(mvpHandle, 1, false, mvpMatrix, 0)

        val colorHandle = GLES30.glGetUniformLocation(program, "u_Color")
        val positionHandle = GLES30.glGetAttribLocation(program, "a_Position")

        GLES30.glEnableVertexAttribArray(positionHandle)

        for ((plane, data) in planes) {
            if (plane.trackingState != TrackingState.TRACKING) continue

            GLES30.glBindBuffer(GLES30.GL_ARRAY_BUFFER, data.vertexBuffer)
            GLES30.glVertexAttribPointer(positionHandle, 3, GLES30.GL_FLOAT, false, 12, 0)

            val color = floatArrayOf(0.4f, 0.31f, 0.64f, 0.3f)
            GLES30.glUniform4fv(colorHandle, 1, color, 0)

            GLES30.glDrawArrays(GLES30.GL_TRIANGLE_FAN, 0, data.vertexCount)
        }

        GLES30.glDisableVertexAttribArray(positionHandle)
    }

    fun clear() {
        planes.values.forEach { GLES30.glDeleteBuffers(1, intArrayOf(it.vertexBuffer), 0) }
        planes.clear()
    }

    private fun createProgram() {
        val vertexShader = loadShader(GLES30.GL_VERTEX_SHADER, planeVertexShaderCode)
        val fragmentShader = loadShader(GLES30.GL_FRAGMENT_SHADER, planeFragmentShaderCode)
        program = GLES30.glCreateProgram()
        GLES30.glAttachShader(program, vertexShader)
        GLES30.glAttachShader(program, fragmentShader)
        GLES30.glLinkProgram(program)
    }

    private fun loadShader(type: Int, code: String): Int {
        val shader = GLES30.glCreateShader(type)
        GLES30.glShaderSource(shader, code)
        GLES30.glCompileShader(shader)
        return shader
    }

    data class PlaneData(val vertices: FloatArray) {
        val vertexBuffer: Int = createBuffer()
        val vertexCount: Int = vertices.size / 3

        private fun createBuffer(): Int {
            val buffer = IntArray(1)
            GLES30.glGenBuffers(1, buffer, 0)
            GLES30.glBindBuffer(GLES30.GL_ARRAY_BUFFER, buffer[0])
            GLES30.glBufferData(GLES30.GL_ARRAY_BUFFER, vertices.size * 4, ByteBuffer.wrap(toByteArray(vertices)).order(ByteOrder.nativeOrder()), GLES30.GL_STATIC_DRAW)
            return buffer[0]
        }
    }

    private fun toByteArray(floats: FloatArray): ByteArray {
        val buffer = ByteBuffer.allocateDirect(floats.size * 4)
        buffer.order(ByteOrder.nativeOrder())
        buffer.asFloatBuffer().put(floats)
        return buffer.array()
    }

    companion object {
        private const val planeVertexShaderCode = """
            uniform mat4 u_MVPMatrix;
            attribute vec4 a_Position;
            void main() {
                gl_Position = u_MVPMatrix * a_Position;
            }
        """.trimIndent()

        private const val planeFragmentShaderCode = """
            precision mediump float;
            uniform vec4 u_Color;
            void main() {
                gl_FragColor = u_Color;
            }
        """.trimIndent()
    }
}

class CursorRenderer(private val context: Context) : Renderable {
    private var program: Int = 0
    private var mvpMatrix: FloatArray = FloatArray(16)
    private var anchor: Anchor? = null
    private var visible = false
    private var vertexBuffer: Int = 0

    fun setMVPMatrix(matrix: FloatArray) {
        mvpMatrix = matrix.clone()
    }

    fun setAnchor(newAnchor: Anchor) {
        anchor = newAnchor
    }

    fun setVisible(visible: Boolean) {
        this.visible = visible
    }

    override fun render(renderContext: RenderContext?) {
        if (!visible || anchor == null || program == 0) return

        GLES30.glUseProgram(program)
        val mvpHandle = GLES30.glGetUniformLocation(program, "u_MVPMatrix")
        GLES30.glUniformMatrix4fv(mvpHandle, 1, false, mvpMatrix, 0)

        val colorHandle = GLES30.glGetUniformLocation(program, "u_Color")
        val sizeHandle = GLES30.glGetUniformLocation(program, "u_Size")
        val positionHandle = GLES30.glGetAttribLocation(program, "a_Position")

        GLES30.glEnableVertexAttribArray(positionHandle)
        GLES30.glBindBuffer(GLES30.GL_ARRAY_BUFFER, vertexBuffer)
        GLES30.glVertexAttribPointer(positionHandle, 3, GLES30.GL_FLOAT, false, 12, 0)

        val color = floatArrayOf(0.4f, 0.31f, 0.64f, 1f)
        GLES30.glUniform4fv(colorHandle, 1, color, 0)
        GLES30.glUniform1f(sizeHandle, 0.02f)

        GLES30.glDrawArrays(GLES30.GL_POINTS, 0, 1)

        GLES30.glDisableVertexAttribArray(positionHandle)
    }

    fun clear() {
        if (vertexBuffer != 0) {
            GLES30.glDeleteBuffers(1, intArrayOf(vertexBuffer), 0)
            vertexBuffer = 0
        }
    }

    private fun createProgram() {
        val vertexShader = loadShader(GLES30.GL_VERTEX_SHADER, cursorVertexShaderCode)
        val fragmentShader = loadShader(GLES30.GL_FRAGMENT_SHADER, cursorFragmentShaderCode)
        program = GLES30.glCreateProgram()
        GLES30.glAttachShader(program, vertexShader)
        GLES30.glAttachShader(program, fragmentShader)
        GLES30.glLinkProgram(program)

        val vertices = floatArrayOf(0f, 0f, 0f)
        val buffer = IntArray(1)
        GLES30.glGenBuffers(1, buffer, 0)
        GLES30.glBindBuffer(GLES30.GL_ARRAY_BUFFER, buffer[0])
        GLES30.glBufferData(GLES30.GL_ARRAY_BUFFER, vertices.size * 4, ByteBuffer.wrap(toByteArray(vertices)).order(ByteOrder.nativeOrder()), GLES30.GL_STATIC_DRAW)
        vertexBuffer = buffer[0]
    }

    private fun loadShader(type: Int, code: String): Int {
        val shader = GLES30.glCreateShader(type)
        GLES30.glShaderSource(shader, code)
        GLES30.glCompileShader(shader)
        return shader
    }

    private fun toByteArray(floats: FloatArray): ByteArray {
        val buffer = ByteBuffer.allocateDirect(floats.size * 4)
        buffer.order(ByteOrder.nativeOrder())
        buffer.asFloatBuffer().put(floats)
        return buffer.array()
    }

    companion object {
        private const val cursorVertexShaderCode = """
            uniform mat4 u_MVPMatrix;
            attribute vec4 a_Position;
            void main() {
                gl_Position = u_MVPMatrix * a_Position;
            }
        """.trimIndent()

        private const val cursorFragmentShaderCode = """
            precision mediump float;
            uniform vec4 u_Color;
            uniform float u_Size;
            void main() {
                float dist = length(gl_PointCoord - vec2(0.5));
                if (dist > 0.5) discard;
                float alpha = 1.0 - smoothstep(0.3, 0.5, dist);
                gl_FragColor = vec4(u_Color.rgb, u_Color.a * alpha);
            }
        """.trimIndent()
    }
}